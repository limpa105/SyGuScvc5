+  Trace("sygus-bg-mem") << "  allowVars  = " << allowVars << "\n";
+
+  if (stn.isNull() || !stn.isDatatype())
+  {
+    Trace("sygus-bg-mem") << "  FAIL: stn is null or not a datatype\n";
+    Trace("sygus-bg-mem") << "====================================================\n";
