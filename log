+  Trace("sygus-bg-mem") << "  isBuiltinTermInSygusGrammar(t)  = " << r0 << "\n";
+  Trace("sygus-bg-mem") << "  isBuiltinTermInSygusGrammar(rt) = " << r1 << "\n";
+
+  bool ret = r1;
+
+  Trace("sygus-bg-mem") << "  ==> returning " << ret << "\n";
