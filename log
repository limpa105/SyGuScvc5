+    return n.getAttribute(SygusBlockingTypeAttr());
+  }
+  return TypeNode::null();
+}
+
+bool SygusUtils::hasSygusBlockingType(Node n)
+{
+  return n.hasAttribute(SygusBlockingTypeAttr());
